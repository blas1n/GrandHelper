<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Mic circle with wave bars inside -->
    <FrameLayout
        android:layout_width="@dimen/mic_circle_size"
        android:layout_height="@dimen/mic_circle_size"
        android:layout_marginBottom="16dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_mic_circle" />

        <!-- Wave bars container -->
        <LinearLayout
            android:id="@+id/wave_bars"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View android:layout_width="@dimen/wave_bar_width" android:layout_height="8dp"
                android:layout_marginEnd="3dp" android:background="@color/text_white" />
            <View android:layout_width="@dimen/wave_bar_width" android:layout_height="8dp"
                android:layout_marginEnd="3dp" android:background="@color/text_white" />
            <View android:layout_width="@dimen/wave_bar_width" android:layout_height="8dp"
                android:layout_marginEnd="3dp" android:background="@color/text_white" />
            <View android:layout_width="@dimen/wave_bar_width" android:layout_height="8dp"
                android:layout_marginEnd="3dp" android:background="@color/text_white" />
            <View android:layout_width="@dimen/wave_bar_width" android:layout_height="8dp"
                android:background="@color/text_white" />

        </LinearLayout>

    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/listening_title"
        android:textColor="@color/text_white"
        android:textSize="@dimen/text_large"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/listening_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_small" />

    <!-- Partial speech text -->
    <TextView
        android:id="@+id/partial_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:background="@drawable/bg_speech_bubble"
        android:textColor="@color/primary"
        android:textSize="@dimen/text_body"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
